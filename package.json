{
  "name": "docs-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "DocsViewer — client-side SPA xem .docx/.xlsx/PDF + trích xuất nội dung + tìm kiếm in-document",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "docx-preview": "0.3.7",
    "mammoth": "1.12.0",
    "pdfjs-dist": "6.0.227",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vitest": "4.1.9"
  }
}
